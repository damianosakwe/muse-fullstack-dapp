# ============================================================================
# FRONTEND ENVIRONMENT CONFIGURATION (.env.example)
# ============================================================================
# Location: apps/frontend/.env.example
#
# INSTRUCTIONS:
# 1. Copy this file and name it .env in apps/frontend/
# 2. Fill in values for your development/production environment
# 3. Vite variables MUST start with VITE_ to be exposed to frontend
# 4. Do NOT commit .env to version control
# ============================================================================

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Backend API endpoint URL accessible from the browser
# Development: http://localhost:3001
# Staging: https://api-staging.muse.example.com
# Production: https://api.muse.example.com
VITE_API_URL=http://localhost:3001

# ============================================================================
# ERROR TRACKING & MONITORING
# ============================================================================

# Sentry DSN for error tracking (optional)
# Enable error tracking and session monitoring
# Get from: https://sentry.io/projects/
# Format: https://key@sentry.io/project-id
VITE_SENTRY_DSN=

# ============================================================================
# ENVIRONMENT DESCRIPTOR
# ============================================================================

# Environment name for logging and feature flags
# Values: development | staging | production
VITE_ENVIRONMENT=development

# ============================================================================
# END OF FRONTEND CONFIGURATION
# ============================================================================
