# ============================================================================
# BACKEND ENVIRONMENT CONFIGURATION (.env.example)
# ============================================================================
# Location: apps/backend/.env.example
# 
# INSTRUCTIONS:
# 1. Copy this file and rename to .env in apps/backend/
# 2. Update values with your actual configuration
# 3. NEVER commit .env to version control
# 4. Each environment should have unique secrets
#
# SECURITY NOTES:
# - JWT_SECRET: Use strong random value (min 32 chars)
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# - Sensitive keys: Do NOT expose in logs or public repositories
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Application server port (default: 3001)
PORT=3001

# Environment mode: development | production | test
NODE_ENV=development

# Frontend application URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# MongoDB connection URI
# Local: mongodb://localhost:27017/muse
# MongoDB Cloud: mongodb+srv://user:pass@cluster.mongodb.net/muse?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/muse

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret Key - CRITICAL SECURITY
# Generate a strong random value using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_use_strong_random_value

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# CACHING - REDIS CONFIGURATION
# ============================================================================
# If Redis is unavailable, backend uses in-memory fallback

# Redis connection URL (recommended way)
REDIS_URL=redis://localhost:6379

# Alternative: Individual Redis parameters
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache expiration time in seconds (default: 300)
CACHE_TTL=300

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit window duration in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW=900000

# Maximum requests allowed per window
RATE_LIMIT_MAX=100

# ============================================================================
# LOGGING
# ============================================================================

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ============================================================================
# IMAGE OPTIMIZATION & STORAGE
# ============================================================================

# Maximum image cache size in MB
IMAGE_CACHE_SIZE=500

# ============================================================================
# STELLAR BLOCKCHAIN CONFIGURATION
# ============================================================================

# Stellar network selection: testnet | mainnet
STELLAR_NETWORK=testnet

# Stellar Soroban RPC endpoint URL
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban-mainnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Stellar smart contract ID (deployed contract address)
# Format: CAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STELLAR_CONTRACT_ID=your_contract_id_here

# ============================================================================
# AI SERVICES INTEGRATION
# ============================================================================

# OpenAI API Key (for text/image generation features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Stability AI API Key (for AI image generation)
# Get from: https://api.stability.ai
STABILITY_API_KEY=your_stability_api_key_here

# ============================================================================
# API KEY MANAGEMENT
# ============================================================================

# Secret for hashing API keys (use strong random value)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
API_KEY_HASH_SECRET=your_api_key_hash_secret_here_minimum_64_chars

# API key default settings
API_KEY_DEFAULT_REQUESTS=1000
API_KEY_DEFAULT_WINDOW=3600000

# ============================================================================
# BACKGROUND JOB PROCESSING
# ============================================================================

# Job queue Redis database (use different DB from cache)
JOB_QUEUE_REDIS_DB=1

# Job processing settings
JOB_CONCURRENCY=5
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_DELAY=2000

# Job retention settings
JOB_KEEP_COMPLETED=100
JOB_KEEP_FAILED=50

# ============================================================================
# ADVANCED CONFIGURATION (Optional)
# ============================================================================

# Health check endpoint interval in seconds
HEALTH_CHECK_INTERVAL=30

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# Maximum number of artifacts stored in memory
MAX_ARTIFACTS=1000

# ============================================================================
# END OF BACKEND CONFIGURATION
# ============================================================================
