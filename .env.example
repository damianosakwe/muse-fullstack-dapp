# ============================================================================
# MUSE FULLSTACK DAPP - ENVIRONMENT CONFIGURATION
# ============================================================================
# This is an example environment configuration file for the entire Muse dApp.
#
# INSTRUCTIONS:
# 1. Copy this file to .env in your root directory
# 2. Fill in the values with your actual configuration
# 3. NEVER commit .env files to version control
# 4. Keep sensitive data (keys, secrets) secure
#
# SECURITY WARNINGS:
# ⚠️  JWT_SECRET, DEPLOYER_PRIVATE_KEY, and API keys are CRITICAL
# ⚠️  Do NOT expose these values in logs, error messages, or version control
# ⚠️  Each environment (dev, test, prod) should have unique secret values
# ============================================================================

# ============================================================================
# BACKEND SERVER CONFIGURATION
# ============================================================================

# Server port
PORT=3001

# Environment mode: development, production, test
NODE_ENV=development

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# MongoDB connection string
# Format: mongodb://[username:password@]host[:port]/dbname?options
# Examples:
#   Local: mongodb://localhost:27017/muse
#   MongoDB Cloud: mongodb+srv://user:password@cluster.mongodb.net/muse?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/muse
DATABASE_URL=mongodb://localhost:27017/muse

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret - CRITICAL: Use a strong, random value
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters recommended
JWT_SECRET=your_jwt_secret_key_here_do_not_expose_use_strong_random_value

# CORS Origins (comma-separated if multiple)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# REDIS CACHE CONFIGURATION (Optional)
# ============================================================================
# If Redis is unavailable, the backend falls back to in-memory caching

# Redis connection URL (alternative to individual params below)
REDIS_URL=redis://localhost:6379

# Individual Redis parameters
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache TTL in seconds (default: 300)
CACHE_TTL=300

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW=900000

# Max requests per window (varies by tier)
RATE_LIMIT_MAX=100

# ============================================================================
# LOGGING
# ============================================================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# ============================================================================
# IMAGE OPTIMIZATION
# ============================================================================

# Maximum image cache size in MB
IMAGE_CACHE_SIZE=500

# ============================================================================
# STELLAR BLOCKCHAIN CONFIGURATION
# ============================================================================

# Stellar network: testnet or mainnet
# Use 'testnet' for development, 'mainnet' for production
STELLAR_NETWORK=testnet

# Stellar Soroban RPC endpoint
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban-mainnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Deployed Stellar contract ID
# Get this after deploying your contract to the network
STELLAR_CONTRACT_ID=CAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# AI SERVICES INTEGRATION
# ============================================================================

# OpenAI API Key for AI art generation
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stability AI API Key for image generation/editing
# Get from: https://api.stability.ai
STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# BLOCKCHAIN DEPLOYMENT CONFIGURATION
# ============================================================================

# Stellar Deployer Private Key - CRITICAL
# Private key of the account that will deploy contracts
# Format: Start with S... for Stellar keys
# ⚠️  NEVER expose this in public environments
DEPLOYER_PRIVATE_KEY=Sxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ethereum/EVM Private Key - CRITICAL
# Private key for contract deployment on EVM chains
# ⚠️  NEVER expose this in public environments
PRIVATE_KEY=0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# NETWORK RPC ENDPOINTS (for Hardhat/Contract Deployment)
# ============================================================================

# Sepolia Testnet RPC URL
# Get from Infura, Alchemy, or other providers
# https://infura.io or https://alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-key-here

# Ethereum Mainnet RPC URL (use with caution in production)
MAINNET_RPC_URL=https://mainnet.infura.io/v3/your-key-here

# ============================================================================
# ETHERSCAN & BLOCK EXPLORER INTEGRATION
# ============================================================================

# Etherscan API Key for contract verification
# Get from: https://etherscan.io/apis
ETHERSCAN_API_KEY=your-etherscan-api-key-here

# ============================================================================
# CONTRACT COMPILATION & GAS REPORTING
# ============================================================================

# Enable gas reporting for contract deployments
# Can be any value to enable (e.g., "true", "1", or just set the variable)
REPORT_GAS=true

# ============================================================================
# ERROR TRACKING (Frontend)
# ============================================================================

# Sentry DSN for error tracking (optional)
# Format: https://key@sentry.io/project-id
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Backend API URL (for frontend to communicate with backend)
VITE_API_URL=http://localhost:3001

# Environment descriptor for frontend logging
VITE_ENVIRONMENT=development

# ============================================================================
# TESTING CONFIGURATION
# ============================================================================
# Note: Copy to .env.test for testing environments

# TEST_PORT=5001
# TEST_NODE_ENV=test
# TEST_MONGODB_URI=mongodb://localhost:27017/muse_test

# ============================================================================
# ADVANCED CONFIGURATION (Optional)
# ============================================================================

# Health check interval in seconds
HEALTH_CHECK_INTERVAL=30

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# Max artifacts stored in memory
MAX_ARTIFACTS=1000

# ============================================================================
# END OF ENVIRONMENT CONFIGURATION
# ============================================================================
