# ============================================================================
# BACKEND TEST ENVIRONMENT CONFIGURATION (.env.test)
# ============================================================================
# Location: apps/backend/.env.test
#
# This file is used during automated tests (npm test)
# It uses a separate test database and minimal external dependencies
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Test server port (different from development to avoid conflicts)
PORT=5001

# Environment is always test
NODE_ENV=test

# Frontend URL for test CORS
FRONTEND_URL=http://localhost:3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Separate MongoDB database for tests (won't affect development data)
MONGODB_URI=mongodb://localhost:27017/muse_test

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Test JWT secret (can be simple for testing)
JWT_SECRET=test_jwt_secret_for_automated_tests_only

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Leave Redis empty to use fallback in-memory cache during tests
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=

# Shorter cache TTL for faster tests
CACHE_TTL=60

# ============================================================================
# RATE LIMITING
# ============================================================================

# Disable or increase rate limiting for tests
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=10000

# ============================================================================
# LOGGING
# ============================================================================

# Minimal logging during tests to reduce noise
LOG_LEVEL=error

# ============================================================================
# STELLAR BLOCKCHAIN
# ============================================================================

# Use Stellar testnet for tests
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_CONTRACT_ID=test_contract_id

# ============================================================================
# AI SERVICES
# ============================================================================

# Mock keys for testing (won't be used with proper mocking)
OPENAI_API_KEY=test_key_not_used_in_mocked_tests
STABILITY_API_KEY=test_key_not_used_in_mocked_tests

# ============================================================================
# OTHER CONFIGURATION
# ============================================================================

HEALTH_CHECK_INTERVAL=30
REQUEST_TIMEOUT=30000
MAX_ARTIFACTS=100
