# ============================================================================
# SMART CONTRACTS ENVIRONMENT CONFIGURATION (.env.example)
# ============================================================================
# Location: packages/contracts/.env.example
#
# INSTRUCTIONS:
# 1. Copy this file to .env in packages/contracts/
# 2. Set deployment and network configuration
# 3. NEVER commit .env file to version control
# 4. Use separate keys for deploying to different networks
#
# SECURITY WARNINGS:
# ⚠️  DEPLOYER_PRIVATE_KEY: Controls contract deployment and ownership
# ⚠️  NEVER expose private keys in public repositories or logs
# ⚠️  Test networks only for initial testing
# ============================================================================

# ============================================================================
# STELLAR NETWORK CONFIGURATION
# ============================================================================

# Stellar network: standalone, testnet, or mainnet
STELLAR_NETWORK=testnet

# RPC endpoints for different networks
STANDALONE_RPC_URL=http://localhost:8000/soroban/rpc
TESTNET_RPC_URL=https://soroban-testnet.stellar.org
MAINNET_RPC_URL=https://soroban.stellar.org

# Active RPC URL (matches selected network)
DEPLOYED_RPC_URL=https://soroban-testnet.stellar.org

# ============================================================================
# DEPLOYMENT KEYS - CRITICAL SECURITY
# ============================================================================

# Stellar deployer private key - CRITICAL
# Format: Starts with 'S' followed by characters
# Generate at: https://laboratory.stellar.org
# ⚠️  NEVER expose - controls contract deployment and ownership
DEPLOYER_PRIVATE_KEY=your_stellar_private_key_here

# Ethereum/Hardhat private key (if deploying to EVM chains)
# Format: 0x followed by 64 hex characters
PRIVATE_KEY=0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# TEST NETWORK FUNDS
# ============================================================================

# Friendbot URL for requesting test XLM on testnet
FRIENDBOT_URL=https://friendbot.stellar.org

# ============================================================================
# NETWORK PASSPHRASES
# ============================================================================

# Network passphrases for signing transactions
STANDALONE_NETWORK=Standalone Network ; February 2017
TESTNET_NETWORK=Test SDF Network ; September 2015
MAINNET_NETWORK=Public Global Stellar Network ; September 2015

# ============================================================================
# CONTRACT VERIFICATION (Optional)
# ============================================================================

# Etherscan API Key (for contract verification)
ETHERSCAN_API_KEY=your-etherscan-api-key-here

# ============================================================================
# HARDHAT CONFIGURATION
# ============================================================================

# Enable gas reporting
REPORT_GAS=true

# Coinmarketcap API key for USD conversion
COINMARKETCAP_API_KEY=your-api-key-here

# ============================================================================
# DEPLOYMENT OPTIONS
# ============================================================================

# Skip verification during deployment
SKIP_VERIFY=false

# Dry run deployment (simulate without broadcasting)
DRY_RUN=false

# Verbose logging
VERBOSE=true

# ============================================================================
# END OF CONTRACTS CONFIGURATION
# ============================================================================
